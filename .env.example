# LINE Bot 設定
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Linear 設定
LINEAR_API_KEY=your-linear-api-key
LINEAR_TEAM_ID=your-linear-team-id

# リマインド認証
REMIND_SECRET=your-random-secret-string

# Gemini AI 設定
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ユーザーマッピング（JSON配列）
# LINE ↔ Linear のユーザー対応表。空配列の場合は全員「未登録」扱い
# 例: [{"lineUserId":"U...","linearUserId":"uuid...","displayName":"山田","aliases":["yamada","@yamada"]}]
USER_MAP_JSON=[]

# サーバーポート（Cloud Run では 8080 を推奨）
PORT=8080
